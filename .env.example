# ServiceNow Instance
SN_INSTANCE=<your-instance-id>          # e.g. mycompany
SN_HOST=<your-instance-id>.service-now.com
SN_USER=admin
SN_PASSWORD=<your-sn-admin-password>

# MID Server User
MID_INSTANCE_USERNAME=mid.server
MID_INSTANCE_PASSWORD=<your-mid-password>

# Metadata Collector
SN_METADATA_COLLECTOR_SYSID=<sys_id of Neon metadata collector record>

# Snowflake
SF_ACCOUNT=<account-locator>            # e.g. abc123-xy12345
SF_USER=<snowflake-username>
SF_PASSWORD=<snowflake-password>

# Neon PostgreSQL
NEON_API_KEY=<neon-api-key>
NEON_ORG_ID=<neon-org-id>
NEON_PROJECT_ID=<neon-project-id>
NEON_HOST=<neon-endpoint>.neon.tech
NEON_PORT=5432
NEON_DB=neondb
NEON_USER=neondb_owner
NEON_PASSWORD=<neon-db-password>

# SN Catalog sys_ids (populated after sn_govern.py has run once)
SN_RISK_DOMAIN_SYS_ID=<sys_id of APRA Risk Management domain>
SN_FIN_DOMAIN_SYS_ID=<sys_id of Financial Operations domain>
